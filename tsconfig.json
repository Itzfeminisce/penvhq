{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@penvhq/core": ["./packages/core/src/index.ts"],
      "@penvhq/runtime": ["./packages/runtime/src/index.ts"],
      "@penvhq/provider-filesystem": ["./packages/providers/filesystem/src/index.ts"],
      "@penvhq/provider-contract": ["./packages/providers/contract/src/index.ts"],
      "@penvhq/sink-github": ["./packages/sinks/github/src/index.ts"],
      "@penvhq/cli": ["./packages/cli/src/index.ts"]
    }
  },
  "include": [
    "packages/**/src/**/*.ts",
    "packages/**/*.test-d.ts",
    "*.ts",
    "packages/**/tsup.config.ts"
  ]
}
