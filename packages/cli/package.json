{
  "name": "@penv/cli",
  "version": "0.0.0",
  "description": "penv's command line. Dependency budget is deliberately looser than the runtime's.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@penv/core": "workspace:*",
    "@penv/provider-filesystem": "workspace:*",
    "@penv/sink-github": "workspace:*",
    "@penv/runtime": "workspace:*",
    "citty": "0.2.2",
    "jiti": "2.7.0"
  },
  "peerDependencies": {
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "zod": "4.4.3"
  }
}
