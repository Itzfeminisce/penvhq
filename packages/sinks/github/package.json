{
  "name": "@penv/sink-github",
  "version": "0.0.0",
  "description": "The GitHub Actions Secrets sink — a write-only destination penv pushes to through the gh CLI.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
